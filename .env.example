# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Generate with: openssl rand -hex 32
JWT_SECRET=replace-this-with-a-random-64-char-hex-string

# ── Email (Resend.com — free tier: 3,000 emails/month) ───────────────────────
# Sign up at https://resend.com, verify a domain, then paste the API key below.
# Without this, sign-up verification and password-reset emails are silently skipped.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address shown in emails — must match a verified Resend domain.
FROM_EMAIL=ClassMind AI <noreply@yourdomain.com>

# ── App ───────────────────────────────────────────────────────────────────────
# Public-facing URL (used in email links). No trailing slash.
APP_URL=https://your-app.up.railway.app

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=https://your-app.up.railway.app

NODE_ENV=production
PORT=3000
